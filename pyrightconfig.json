{
    "pythonVersion": "3.12",
    "pythonPlatform": "Linux",
    "executionEnvironments": [
        {
            "root": ".",
            "pythonVersion": "3.12",
            "extraPaths": [
                "."
            ]
        }
    ],
    "include": [
        "api",
        "db",
        "entities",
        "services"
    ],
    "exclude": [
        "**/__pycache__",
        ".venv"
    ],
    "reportMissingImports": true,
    "reportMissingTypeStubs": false,
    "stubPath": "./typings"
}

